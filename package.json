{
  "name": "utah",
  "version": "2.0.0",
  "description": "Geographically accurate 3D terrain visualization of Utah",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite build && vite preview --open",
    "start": "vite preview --open",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "gsap": "^3.14.2",
    "seedrandom": "^3.0.5",
    "simplex-noise": "^4.0.3",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/seedrandom": "^3.0.8",
    "@types/sharp": "^0.31.1",
    "@types/three": "^0.183.1",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
